# Virtual environments — never commit these
v1/venv/
v2/.venv-yolo/
**/venv/
**/.venv/
**/.venv-yolo/

# Python bytecode and caches
**/__pycache__/
**/*.pyc
**/*.pyo

# Training outputs and runtime artifacts
v2/runs/
v2/ml/yolo/outputs/
v2/ml/yolo/eval/
runs/

# Large model weights — tracked for now, uncomment to ignore if repo gets too big
# v2/ml/yolo/weights/*.pt

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE and editor files
.vscode/
.idea/
*.swp
*~

# Model weights — too large for git, distributed separately
**/*.pt
**/*.pkl
**/*.onnx

# Video files — too large for git
**/*.mp4
**/*.mov
**/*.avi
**/*.mkv
